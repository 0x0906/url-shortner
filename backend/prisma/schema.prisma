datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                 String    @id @default(uuid()) @db.Uuid
  name               String
  email              String    @unique
  password_hash      String
  is_verified        Boolean   @default(false)
  verification_token String?   @unique
  reset_token        String?   @unique
  reset_token_expires DateTime?
  created_at         DateTime  @default(now())
  urls               Url[]
  sessions           Session[]

  @@map("users")
}

model Session {
  id            String   @id @default(uuid()) @db.Uuid
  user_id       String   @db.Uuid
  refresh_token String   @unique @db.Text
  device_name   String?
  ip_address    String?
  expires_at    DateTime
  created_at    DateTime @default(now())
  user          User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("sessions")
}

model Url {
  id           String    @id @default(uuid()) @db.Uuid
  original_url String    @db.Text
  short_code   String    @unique
  custom_alias String?   @unique
  click_count  Int       @default(0)
  expires_at   DateTime?
  password_hash String?
  is_one_time  Boolean   @default(false)
  is_active    Boolean   @default(true)
  user_id      String?   @db.Uuid
  created_at   DateTime  @default(now())
  user         User?     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  visits       Visit[]

  @@index([user_id])
  @@index([short_code])
  @@map("urls")
}

model Visit {
  id          String   @id @default(uuid()) @db.Uuid
  url_id      String   @db.Uuid
  ip_address  String?
  user_agent  String?  @db.Text
  visited_at  DateTime @default(now())
  url         Url      @relation(fields: [url_id], references: [id], onDelete: Cascade)

  @@index([url_id])
  @@map("visits")
}
